# Copy this to real.env for local or EC2 use. real.env is intentionally ignored.

# Required for browser authentication.
ECONOMIST_EMAIL=
ECONOMIST_PASSWORD=

# Set true after installing the browser extra and Playwright Chromium.
ECONOMIST_BROWSER_FETCH_ENABLED=false

# Browser session/cache paths. Keep these off Git.
ECONOMIST_BROWSER_USER_DATA_DIR=.cache/economist-browser-profile
ECONOMIST_BROWSER_STORAGE_STATE=.cache/economist-browser-state.json

# Optional private refresh endpoint token for the HTTP server.
ECONOMIST_REFRESH_TOKEN=

# Optional runtime tuning.
ECONOMIST_HOST=127.0.0.1
ECONOMIST_PORT=8080
